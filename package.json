{
  "name": "cursedcode",
  "version": "1.0.0",
  "private": true,
  "description": "A TypeScript Discord bot with a /park slash command.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node --watch --import tsx src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "register": "node --import tsx src/register-commands.ts"
  },
  "dependencies": {
    "@discordjs/voice": "latest",
    "discord.js": "latest",
    "smol-toml": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
